# Supabase credentials.
#
# By DEFAULT the app runs on built-in in-memory mock data — no backend
# required, `npm run dev` just works. This is deliberate: the original hosted
# database is gone, so demo mode keeps the UI runnable for a presentation.
#
# To use a real database instead, copy this file to `.env`, set
# VITE_USE_SUPABASE=true, fill in the values from your Supabase project
# (Project Settings -> API), and apply the migration in supabase/migrations/
# plus seed some rows.
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
